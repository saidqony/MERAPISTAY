# ─── Payload CMS ────────────────────────────────────────────────────
PAYLOAD_SECRET=ganti-dengan-string-acak-minimal-32-karakter

# ─── Supabase PostgreSQL (Transaction Pooler — port 6543) ───────────
# PENTING: Gunakan Transaction Pooler, bukan Direct Connection!
DATABASE_URI=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ─── Supabase Storage S3-Compatible ─────────────────────────────────
S3_ENDPOINT=https://[project-ref].supabase.co/storage/v1/s3
S3_BUCKET=homestay-media
S3_ACCESS_KEY_ID=ganti-dengan-supabase-s3-access-key
S3_SECRET_ACCESS_KEY=ganti-dengan-supabase-s3-secret-key
S3_REGION=ap-southeast-1

# ─── Resend Email Service ────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=invoice@qonypro.cloud

# ─── Next.js / Vercel ───────────────────────────────────────────────
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
